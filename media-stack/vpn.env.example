# Copy to /opt/media-stack/vpn.env inside CT 106 and fill in outside Git.
# AirVPN WireGuard is the intended default for this stack.

VPN_SERVICE_PROVIDER=airvpn
VPN_TYPE=wireguard

# From the AirVPN WireGuard config generator.
WIREGUARD_PRIVATE_KEY=replace-with-secret
WIREGUARD_PRESHARED_KEY=replace-with-secret
WIREGUARD_ADDRESSES=replace-with-vpn-address-cidr

# Pick a provider/server location that supports your account and port forwarding.
SERVER_COUNTRIES=United States

# qBittorrent should listen on the port forwarded by the VPN provider.
# Also set the same value in the qBittorrent Web UI.
FIREWALL_VPN_INPUT_PORTS=replace-with-forwarded-port
