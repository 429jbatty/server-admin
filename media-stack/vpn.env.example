# Copy to /opt/media-stack/vpn.env inside CT 106 and fill in outside Git.
# Keep the real file out of Git. It contains the Proton WireGuard private key.

# Exact Proton WireGuard endpoint mode. This uses a Proton-generated WireGuard
# config with Gluetun's custom provider support, while Proton's NAT-PMP
# port-forwarding integration is selected explicitly below.
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard

# From the Proton WireGuard config generator.
WIREGUARD_PRIVATE_KEY=replace-with-secret
WIREGUARD_PUBLIC_KEY=replace-with-proton-peer-public-key
WIREGUARD_ADDRESSES=replace-with-proton-ipv4-address-cidr
WIREGUARD_ENDPOINT_IP=replace-with-proton-endpoint-ip
WIREGUARD_ENDPOINT_PORT=51820
WIREGUARD_ALLOWED_IPS=0.0.0.0/0
WIREGUARD_PERSISTENT_KEEPALIVE_INTERVAL=25s

# Proton NAT-PMP port forwarding. Gluetun writes the current forwarded port
# here; set qBittorrent's listening port to match it.
VPN_PORT_FORWARDING=on
VPN_PORT_FORWARDING_PROVIDER=protonvpn
VPN_PORT_FORWARDING_PORTS_COUNT=1
VPN_PORT_FORWARDING_STATUS_FILE=/gluetun/forwarded_port
VPN_PORT_FORWARDING_UP_COMMAND=/bin/sh -c 'wget -O- -nv --tries=30 --waitretry=2 --retry-connrefused --post-data "json={\"listen_port\":{{PORT}},\"current_network_interface\":\"{{VPN_INTERFACE}}\",\"random_port\":false,\"upnp\":false}" http://127.0.0.1:8080/api/v2/app/setPreferences'
VPN_PORT_FORWARDING_DOWN_COMMAND=/bin/sh -c 'wget -O- -nv --tries=10 --waitretry=2 --retry-connrefused --post-data "json={\"listen_port\":0,\"current_network_interface\":\"lo\"}" http://127.0.0.1:8080/api/v2/app/setPreferences || true'

# Allow qBittorrent and Prowlarr Web UIs on the Docker/LAN side of Gluetun.
# Torrent/indexer traffic still exits through the VPN tunnel only.
FIREWALL_INPUT_PORTS=8080,9696
FIREWALL_OUTBOUND_SUBNETS=172.16.0.0/12,192.168.1.0/24
